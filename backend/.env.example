NODE_ENV=development
RELEASE_VERSION=local-dev
PORT=4000

# Direct DB URL (port 5432). Keep as fallback.
SUPABASE_DB_URL=postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Required in production for lower latency + better reliability: Supabase pooler transaction URL (port 6543).
# Example format:
# postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
SUPABASE_DB_POOL_URL=

# Supabase project URL and service role key (Project Settings -> API)
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
# Required in production for fastest local JWT verification (no upstream auth round-trip).
# Supabase Dashboard -> Authentication -> JWT Settings -> JWT secret
SUPABASE_JWT_SECRET=

# Use explicit origins in production, for example:
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=*
# Express trust proxy value (true/false or hop count like 1).
TRUST_PROXY=1
# Optional: in production, /health/detailed requires this value in x-health-token header.
HEALTH_DETAILS_TOKEN=
# Structured log verbosity: debug | info | warn | error
LOG_LEVEL=info
# Metrics endpoint controls.
METRICS_ENABLED=true
METRICS_WINDOW_MS=300000
# Optional: require x-metrics-token header in production for /metrics.
METRICS_TOKEN=
# Optional alert webhook for ops notifications.
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_MS=300000
ALERT_EVALUATION_INTERVAL_MS=60000
ALERT_P95_LATENCY_MS=1500
ALERT_AUTH_FAILURES_THRESHOLD=20
ALERT_DB_ERRORS_THRESHOLD=10
ALERT_MIN_REQUESTS=30
GROQ_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20
PARSER_RATE_LIMIT_MAX=30
AUTH_UPSTREAM_TIMEOUT_MS=3000
AUTH_UPSTREAM_RETRIES=1
AUTH_UPSTREAM_RETRY_DELAY_MS=300
AUTH_CACHE_TTL_MS=300000
DB_POOL_MAX=20
DB_CONN_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=10000
DB_CONNECT_RETRY_ATTEMPTS=5
DB_CONNECT_RETRY_DELAY_MS=2000
GROQ_TIMEOUT_MS=15000
GROQ_MAX_RETRIES=0
GROQ_IMAGE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_IMAGE_FALLBACK_MODELS=
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# Security default: disable public sign-up unless explicitly enabled.
AUTH_SIGNUP_ENABLED=false
PARSER_QUEUE_ENABLED=true
PARSER_QUEUE_CONCURRENCY=2
PARSER_QUEUE_MAX_ATTEMPTS=3
PARSER_QUEUE_RETRY_DELAY_MS=1000
PARSER_SYNC_WAIT_MS=3000
PARSER_JOB_TTL_MS=3600000
