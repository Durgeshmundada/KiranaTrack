NODE_ENV=development
PORT=4000

# Direct DB URL (port 5432). Keep as fallback.
SUPABASE_DB_URL=postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Required in production for lower latency + better reliability: Supabase pooler transaction URL (port 6543).
# Example format:
# postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
SUPABASE_DB_POOL_URL=

# Supabase project URL and service role key (Project Settings -> API)
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
# Required in production for fastest local JWT verification (no upstream auth round-trip).
# Supabase Dashboard -> Authentication -> JWT Settings -> JWT secret
SUPABASE_JWT_SECRET=

# Use explicit origins in production, for example:
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=*
GROQ_API_KEY=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
PARSER_RATE_LIMIT_MAX=30
AUTH_UPSTREAM_TIMEOUT_MS=3000
AUTH_CACHE_TTL_MS=300000
DB_POOL_MAX=20
DB_CONN_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=10000
GROQ_TIMEOUT_MS=15000
GROQ_MAX_RETRIES=0
GROQ_IMAGE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
