EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
EXPO_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
# Optional: keep false unless you specifically want direct mobile Groq fallback.
EXPO_PUBLIC_ENABLE_DIRECT_GROQ_FALLBACK=false
# Optional parser tuning.
EXPO_PUBLIC_PARSER_TIMEOUT_MS=15000
EXPO_PUBLIC_PARSER_RETRIES=0
# Optional direct Groq fallback tuning.
EXPO_PUBLIC_DIRECT_GROQ_TIMEOUT_MS=18000
EXPO_PUBLIC_DIRECT_GROQ_RETRIES=1
# Optional direct fallback key. Keep this empty in production apps.
EXPO_PUBLIC_GROQ_API_KEY=
