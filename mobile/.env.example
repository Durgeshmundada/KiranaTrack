EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
EXPO_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
# Security default: do NOT send auth tokens to fallback backend unless explicitly enabled.
EXPO_PUBLIC_ENABLE_BACKEND_FALLBACK=false
EXPO_PUBLIC_FALLBACK_API_BASE_URL=
# Optional: keep false unless you specifically want direct mobile Groq fallback.
EXPO_PUBLIC_ENABLE_DIRECT_GROQ_FALLBACK=false
# Optional parser tuning.
EXPO_PUBLIC_PARSER_TIMEOUT_MS=22000
EXPO_PUBLIC_PARSER_RETRIES=1
EXPO_PUBLIC_PARSER_JOB_POLL_INTERVAL_MS=700
EXPO_PUBLIC_PARSER_JOB_POLL_ATTEMPTS=10
# Optional OCR fallback (OCR.space). Keep empty unless OCR key is provisioned.

EXPO_PUBLIC_OCR_TIMEOUT_MS=12000
# Optional direct Groq fallback tuning.
EXPO_PUBLIC_DIRECT_GROQ_TIMEOUT_MS=18000
EXPO_PUBLIC_DIRECT_GROQ_RETRIES=1
# Optional direct fallback key. Keep this empty in production apps.
EXPO_PUBLIC_GROQ_API_KEY=
# Optional crash webhook for release monitoring.
EXPO_PUBLIC_CRASH_WEBHOOK_URL=
EXPO_PUBLIC_OCR_SPACE_API_KEY=K83535029288957